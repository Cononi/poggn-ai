# Prompt before dangerous Git history changes.
prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "prompt",
    justification = "Force push requires user approval.",
    match = ["git push --force origin main"],
)

# Prompt before destructive clean commands.
prefix_rule(
    pattern = ["git", "clean", "-fd"],
    decision = "prompt",
    justification = "Clean deletes untracked files.",
    match = ["git clean -fd"],
)

# Forbid deleting the filesystem root.
prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "Never delete the filesystem root.",
    match = ["rm -rf /"],
)
